// Autoflow — Prisma Schema
// Multi-schema: master_data, transactions, warehouse, reports

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["master_data", "transactions", "warehouse", "reports"]
}

// ─── Enums (master_data) ─────────────────────────────────────────────────────

enum Role {
  CASHIER
  STORE
  SUPERVISOR
  MANAGER
  CFO
  ADMIN

  @@schema("master_data")
}

// ─── Enums (transactions) ────────────────────────────────────────────────────

enum JOStatus {
  OPEN
  IN_PROGRESS
  DONE

  @@schema("transactions")
}

enum ApArStatus {
  OPEN
  PARTIAL
  CLOSED

  @@schema("transactions")
}

enum ClearingStatus {
  OPEN
  CLOSED

  @@schema("transactions")
}

// ─── Enums (warehouse) ───────────────────────────────────────────────────────

enum CountSessionStatus {
  INITIATED
  COUNTING
  PENDING_APPROVAL
  APPROVED
  COMPLETED

  @@schema("warehouse")
}

enum TransferStatus {
  DRAFT
  POSTED

  @@schema("warehouse")
}

enum WriteOffStatus {
  PENDING_APPROVAL
  APPROVED
  POSTED
  REJECTED

  @@schema("warehouse")
}

// ─── Models (master_data) ────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid()) @db.Uuid
  username     String   @unique
  email        String   @unique
  passwordHash String   @map("password_hash")
  displayName  String   @map("display_name")
  roles        Role[]   @default([])
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  refreshTokens RefreshToken[]

  @@map("users")
  @@schema("master_data")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  token     String    @unique
  userId    String    @map("user_id") @db.Uuid
  expiresAt DateTime  @map("expires_at")
  createdAt DateTime  @default(now()) @map("created_at")
  revokedAt DateTime? @map("revoked_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], name: "idx_refresh_token_user_active")
  @@map("refresh_tokens")
  @@schema("master_data")
}

// ─── Models (transactions) ───────────────────────────────────────────────────

model JobOrder {
  id          String   @id @default(uuid()) @db.Uuid
  joNumber    String   @unique @map("jo_number")
  customerId  String   @map("customer_id") @db.Uuid
  status      JOStatus @default(OPEN)
  hasTempDo   Boolean  @default(false) @map("has_temp_do")
  tempDoId    String?  @map("temp_do_id") @db.Uuid
  invoiceId   String?  @map("invoice_id") @db.Uuid
  items       Json
  totalAmount Decimal  @map("total_amount") @db.Decimal(12, 2)
  vatAmount   Decimal  @map("vat_amount") @db.Decimal(12, 2)
  grandTotal  Decimal  @map("grand_total") @db.Decimal(12, 2)
  notes       String?
  createdBy   String   @map("created_by") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([customerId], name: "idx_job_order_customer")
  @@index([status, createdAt], name: "idx_job_order_status_date")
  @@map("job_order")
  @@schema("transactions")
}

model APOpenItem {
  id              String     @id @default(uuid()) @db.Uuid
  vendorId        String     @map("vendor_id") @db.Uuid
  txId            String     @map("tx_id") @db.Uuid
  txType          String     @map("tx_type")
  originalAmount  Decimal    @map("original_amount") @db.Decimal(12, 2)
  remainingAmount Decimal    @map("remaining_amount") @db.Decimal(12, 2)
  vatAmount       Decimal    @map("vat_amount") @db.Decimal(12, 2)
  status          ApArStatus @default(OPEN)
  taxInvoiceNo    String     @map("tax_invoice_no")
  dueDate         DateTime?  @map("due_date")
  period          String
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  allocations APPaymentAllocation[]

  @@index([vendorId, status], name: "idx_ap_open_item_vendor_status")
  @@index([status, dueDate], name: "idx_ap_open_item_status_due")
  @@map("ap_open_item")
  @@schema("transactions")
}

model AROpenItem {
  id              String     @id @default(uuid()) @db.Uuid
  customerId      String     @map("customer_id") @db.Uuid
  txId            String     @map("tx_id") @db.Uuid
  txType          String     @map("tx_type")
  originalAmount  Decimal    @map("original_amount") @db.Decimal(12, 2)
  remainingAmount Decimal    @map("remaining_amount") @db.Decimal(12, 2)
  vatAmount       Decimal    @map("vat_amount") @db.Decimal(12, 2)
  status          ApArStatus @default(OPEN)
  taxInvoiceNo    String?    @map("tax_invoice_no")
  dueDate         DateTime?  @map("due_date")
  period          String
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  allocations ARPaymentAllocation[]

  @@index([customerId, status], name: "idx_ar_open_item_customer_status")
  @@index([status, dueDate], name: "idx_ar_open_item_status_due")
  @@map("ar_open_item")
  @@schema("transactions")
}

model APPaymentAllocation {
  id           String   @id @default(uuid()) @db.Uuid
  paymentTxId  String   @map("payment_tx_id") @db.Uuid
  apOpenItemId String   @map("ap_open_item_id") @db.Uuid
  amount       Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  apOpenItem APOpenItem @relation(fields: [apOpenItemId], references: [id])

  @@index([paymentTxId], name: "idx_ap_alloc_payment_tx")
  @@index([apOpenItemId], name: "idx_ap_alloc_open_item")
  @@map("ap_payment_allocation")
  @@schema("transactions")
}

model ARPaymentAllocation {
  id           String   @id @default(uuid()) @db.Uuid
  paymentTxId  String   @map("payment_tx_id") @db.Uuid
  arOpenItemId String   @map("ar_open_item_id") @db.Uuid
  amount       Decimal  @db.Decimal(12, 2)
  createdAt    DateTime @default(now()) @map("created_at")

  arOpenItem AROpenItem @relation(fields: [arOpenItemId], references: [id])

  @@index([paymentTxId], name: "idx_ar_alloc_payment_tx")
  @@index([arOpenItemId], name: "idx_ar_alloc_open_item")
  @@map("ar_payment_allocation")
  @@schema("transactions")
}

model GrIrClearing {
  id             String         @id @default(uuid()) @db.Uuid
  grReturnTxId   String         @map("gr_return_tx_id") @db.Uuid
  grReceiveTxId  String         @map("gr_receive_tx_id") @db.Uuid
  vendorId       String         @map("vendor_id") @db.Uuid
  itemId         String         @map("item_id") @db.Uuid
  qty            Decimal        @db.Decimal(12, 4)
  clearingAmount Decimal        @map("clearing_amount") @db.Decimal(12, 2)
  status         ClearingStatus @default(OPEN)
  closedByTxId   String?        @map("closed_by_tx_id") @db.Uuid
  closedByType   String?        @map("closed_by_type")
  ppvAmount      Decimal?       @map("ppv_amount") @db.Decimal(12, 2)
  createdAt      DateTime       @default(now()) @map("created_at")
  closedAt       DateTime?      @map("closed_at")

  @@index([vendorId, status], name: "idx_clearing_vendor_status")
  @@index([grReturnTxId], name: "idx_clearing_gr_return_tx")
  @@map("gr_ir_clearing")
  @@schema("transactions")
}

// ─── Models (warehouse) ──────────────────────────────────────────────────────

model CountSession {
  id          String             @id @default(uuid()) @db.Uuid
  warehouseId String             @map("warehouse_id") @db.Uuid
  status      CountSessionStatus @default(INITIATED)
  initiatedBy String             @map("initiated_by") @db.Uuid
  initiatedAt DateTime           @default(now()) @map("initiated_at")
  completedAt DateTime?          @map("completed_at")
  approvedBy  String?            @map("approved_by") @db.Uuid
  approvedAt  DateTime?          @map("approved_at")
  notes       String?
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  lines CountLine[]

  @@index([warehouseId, status], name: "idx_count_session_warehouse_status")
  @@index([initiatedAt(sort: Desc)], name: "idx_count_session_initiated_at")
  @@map("count_sessions")
  @@schema("warehouse")
}

model CountLine {
  id          String   @id @default(uuid()) @db.Uuid
  sessionId   String   @map("session_id") @db.Uuid
  itemId      String   @map("item_id") @db.Uuid
  systemQty   Decimal  @map("system_qty") @db.Decimal(10, 2)
  physicalQty Decimal? @map("physical_qty") @db.Decimal(10, 2)
  difference  Decimal? @db.Decimal(10, 2)
  systemMa    Decimal  @map("system_ma") @db.Decimal(10, 2)
  isFrozen    Boolean  @default(true) @map("is_frozen")
  reasonCode  String?  @map("reason_code")
  txId        String?  @map("tx_id") @db.Uuid
  createdAt   DateTime @default(now()) @map("created_at")

  session CountSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId], name: "idx_count_line_session")
  @@index([itemId, isFrozen], name: "idx_count_line_item_frozen")
  @@map("count_lines")
  @@schema("warehouse")
}

model TransferOrder {
  id                String         @id @default(uuid()) @db.Uuid
  sourceWarehouseId String         @map("source_warehouse_id") @db.Uuid
  destWarehouseId   String         @map("dest_warehouse_id") @db.Uuid
  status            TransferStatus @default(DRAFT)
  initiatedBy       String         @map("initiated_by") @db.Uuid
  postedAt          DateTime?      @map("posted_at")
  notes             String?
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  lines TransferLine[]

  @@index([sourceWarehouseId], name: "idx_transfer_source_warehouse")
  @@index([destWarehouseId], name: "idx_transfer_dest_warehouse")
  @@index([status], name: "idx_transfer_status")
  @@map("transfer_orders")
  @@schema("warehouse")
}

model TransferLine {
  id         String   @id @default(uuid()) @db.Uuid
  transferId String   @map("transfer_id") @db.Uuid
  itemId     String   @map("item_id") @db.Uuid
  qty        Decimal  @db.Decimal(10, 2)
  unitCost   Decimal  @map("unit_cost") @db.Decimal(10, 2)
  txId       String?  @map("tx_id") @db.Uuid
  createdAt  DateTime @default(now()) @map("created_at")

  transfer TransferOrder @relation(fields: [transferId], references: [id], onDelete: Cascade)

  @@index([transferId], name: "idx_transfer_line_transfer")
  @@index([itemId], name: "idx_transfer_line_item")
  @@map("transfer_lines")
  @@schema("warehouse")
}

model WriteOffRequest {
  id           String        @id @default(uuid()) @db.Uuid
  warehouseId  String        @map("warehouse_id") @db.Uuid
  itemId       String        @map("item_id") @db.Uuid
  qty          Decimal       @db.Decimal(10, 2)
  unitCost     Decimal       @map("unit_cost") @db.Decimal(10, 2)
  totalLoss    Decimal       @map("total_loss") @db.Decimal(10, 2)
  salvageValue Decimal       @default(0) @map("salvage_value") @db.Decimal(10, 2)
  reason       String
  status       WriteOffStatus @default(PENDING_APPROVAL)
  requestedBy  String        @map("requested_by") @db.Uuid
  approvedBy   String?       @map("approved_by") @db.Uuid
  approvedAt   DateTime?     @map("approved_at")
  txId         String?       @map("tx_id") @db.Uuid
  createdAt    DateTime      @default(now()) @map("created_at")
  updatedAt    DateTime      @updatedAt @map("updated_at")

  evidence WriteOffEvidence[]

  @@index([warehouseId, itemId], name: "idx_write_off_warehouse_item")
  @@index([status], name: "idx_write_off_status")
  @@index([requestedBy], name: "idx_write_off_requested_by")
  @@map("write_off_requests")
  @@schema("warehouse")
}

model WriteOffEvidence {
  id         String   @id @default(uuid()) @db.Uuid
  writeOffId String   @map("write_off_id") @db.Uuid
  fileName   String   @map("file_name")
  filePath   String   @map("file_path")
  fileSize   Int      @map("file_size")
  mimeType   String   @map("mime_type")
  uploadedBy String   @map("uploaded_by") @db.Uuid
  uploadedAt DateTime @default(now()) @map("uploaded_at")

  writeOff WriteOffRequest @relation(fields: [writeOffId], references: [id], onDelete: Cascade)

  @@index([writeOffId], name: "idx_write_off_evidence_write_off")
  @@map("write_off_evidence")
  @@schema("warehouse")
}
